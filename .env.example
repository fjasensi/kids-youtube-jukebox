# Obligatoria: crea una clave para YouTube Data API v3 en Google Cloud.
YOUTUBE_API_KEY=pega_aqui_tu_api_key

# Valores opcionales.
YOUTUBE_REGION_CODE=ES
YOUTUBE_RELEVANCE_LANGUAGE=es
YOUTUBE_SAFE_SEARCH=none
YOUTUBE_MUSIC_ONLY=true
APP_PORT=8000

# PostgreSQL local (usado por compose.yml).
POSTGRES_DB=jukebox
POSTGRES_USER=jukebox
POSTGRES_PASSWORD=cambia_esta_clave_local

# Solo es necesario si ejecutas la app sin compose.
# DATABASE_URL=postgresql+asyncpg://jukebox:cambia_esta_clave_local@db:5432/jukebox
